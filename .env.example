# saleor-odoo-bridge — configuration
#
# Copy this file to `.env` (same directory) and fill in the values.
# Docker Compose reads it automatically. Never commit `.env`.

# ── Postgres (Odoo DB) ─────────────────────────────────────────────────
# POSTGRES_DB=postgres is the service DB; the working DB (ODOO_DB_NAME below)
# is created via the Odoo UI or scripts/odoo_setup.py.
POSTGRES_USER=odoo
POSTGRES_PASSWORD=replace-with-strong-db-password-32chars
POSTGRES_DB=postgres

# ── Odoo ───────────────────────────────────────────────────────────────
# Master password — used to create/delete databases via /web/database/manager.
# 32+ random chars. Not the same thing as the admin user's password.
ODOO_ADMIN_PASSWORD=replace-with-strong-master-password-32chars

# Local Odoo URL (used by scripts/odoo_setup.py and scripts/lib/).
ODOO_URL=http://localhost:8069
ODOO_DB_NAME=odoo

# Login/password of the admin user inside the working DB
# (created at /web/database/create).
ODOO_ADMIN_LOGIN=admin@example.com
ODOO_ADMIN_USER_PASSWORD=replace-with-strong-admin-user-password

# Company + locale applied by scripts/odoo_setup.py. Change to suit your store.
ODOO_COMPANY_NAME=My Company
ODOO_CURRENCY=USD
ODOO_COUNTRY=US
ODOO_TIMEZONE=UTC
ODOO_LANG=en_US

# ── Bridge middleware ──────────────────────────────────────────────────
# Saleor GraphQL endpoint. host.docker.internal resolves on macOS/Windows;
# on Linux it works via extra_hosts in the compose file.
BRIDGE_SALEOR_API_URL=http://host.docker.internal:8000/graphql/
BRIDGE_SALEOR_DEFAULT_CHANNEL=default-channel

# Single ProductType for the whole catalog (see docs/adr/0012).
BRIDGE_SALEOR_PRODUCT_TYPE_NAME=Generic

# Saleor App token for mutations. Usually left empty — it is taken from the
# Redis APL after the bridge app is installed (scripts/install_bridge_app.py).
BRIDGE_SALEOR_APP_TOKEN=

# ── App identity advertised at GET /api/manifest ───────────────────────
# Saleor shows these on the App install screen. Set them to your own values.
BRIDGE_APP_ID=saleor-odoo-bridge
BRIDGE_APP_NAME=Saleor Odoo Sync
BRIDGE_APP_ABOUT=Bidirectional sync between an Odoo back-office and a Saleor storefront.
BRIDGE_APP_HOMEPAGE_URL=https://github.com/BekkiBay/saleor-odoo-bridge
BRIDGE_APP_SUPPORT_URL=https://github.com/BekkiBay/saleor-odoo-bridge/issues
BRIDGE_APP_AUTHOR=saleor-odoo-bridge contributors

# ── Odoo ↔ middleware ──────────────────────────────────────────────────
# Shared secret for the Odoo → middleware webhook (see docs/adr/0011).
# REQUIRED: compose refuses to start without it, and the middleware answers
# 503 to an empty/legacy value (fail-closed). Both Odoo and the middleware
# read this same env var, so rotation = edit .env + `docker compose up -d`.
# Generate with:  openssl rand -hex 32
BRIDGE_ODOO_WEBHOOK_SECRET=replace-with-strong-random-32chars

# Internal middleware URL that Odoo posts events to (docker network).
BRIDGE_MIDDLEWARE_INTERNAL_URL=http://middleware:8080

# Odoo API key for the middleware (create via Preferences → Account Security,
# or run scripts/generate_api_key.py). Odoo caps the TTL at 3 months —
# remember to rotate (see docs/runbooks/api-key-rotation.md).
BRIDGE_ODOO_API_KEY=replace-with-odoo-api-key-from-prefs

# Public URL for receiving Saleor webhooks (ngrok / Cloudflare Tunnel).
# For dev without webhooks (only /health and /api/manifest) localhost is fine.
BRIDGE_MIDDLEWARE_PUBLIC_URL=http://localhost:8080

# Log level: DEBUG for dev, INFO for prod.
BRIDGE_LOG_LEVEL=INFO

# Stock consistency (see docs/adr/0010, docs/adr/0016).
BRIDGE_STOCK_SAFETY_BUFFER=1

# ── Ops alerts (see docs/adr/0008). Optional; empty disables the channel. ──
BRIDGE_SLACK_WEBHOOK_URL=
BRIDGE_OPS_EMAIL=
BRIDGE_ALERT_FROM_EMAIL=saleor-bridge@localhost
BRIDGE_SMTP_HOST=
BRIDGE_SMTP_PORT=25
BRIDGE_SMTP_USER=
BRIDGE_SMTP_PASSWORD=

# ── Saleor admin credentials, used only by scripts/ ────────────────────
# scripts/install_bridge_app.py and scripts/smoke_test.py log in with these
# to register the App. Not read by the middleware itself.
SALEOR_GQL_URL=http://localhost:8000/graphql/
SALEOR_ADMIN_EMAIL=admin@example.com
SALEOR_ADMIN_PASSWORD=admin
