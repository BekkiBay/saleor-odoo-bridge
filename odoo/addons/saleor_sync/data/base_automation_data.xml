<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Automation rules (Phase 3.2): on create/write product.template и
        product.category → серверный action диспетчинга в middleware.

        Без filter_domain по active: чтобы ловить и архивацию (active=False →
        unpublish в Saleor). Решение publish/unpublish принимает usecase по
        product.active.
    -->
    <record id="auto_sync_product_template" model="base.automation">
        <field name="name">Sync product to Saleor</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="trigger">on_create_or_write</field>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_product_template'))]"/>
    </record>

    <record id="auto_sync_product_category" model="base.automation">
        <field name="name">Sync category to Saleor</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="trigger">on_create_or_write</field>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_product_category'))]"/>
    </record>

    <!--
        Phase 3.3 (ADR-0017): stock.quant create/write → sync остатка.
        trigger_field_ids УЗКО на `quantity` — НЕ на reserved_quantity (Saleor сам
        трекает свой reserved; иначе резерв триггерил бы sync, лишний шум/петля).
    -->
    <record id="auto_sync_stock_quant" model="base.automation">
        <field name="name">Sync stock to Saleor</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('stock.field_stock_quant__quantity')])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_stock_quant'))]"/>
    </record>

    <!--
        Phase 3.4 (ADR-0019): sale.order/picking state changes → Saleor.
        on_create_or_write + trigger_field=[state] (а не on_state_set): фитит
        ИМЕННО запись поля state (не шумно), но без привязки к одному target-value
        (on_state_set требует trg_selection_field_id на конкретное значение). Все
        переходы ловит один rule, решение принимает worker (как в stock-flow 3.3).
        Шум доп. отфильтрован в server action (значимые states + наличие binding).
    -->
    <record id="auto_sync_sale_order_state" model="base.automation">
        <field name="name">Sync sale.order state to Saleor</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('sale.field_sale_order__state')])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_sale_order_state'))]"/>
    </record>

    <!--
        Unified status (spec 2026-06-22): fire the SAME dispatch when the
        canonical justix_status changes. Critical for the manual "delivered"
        tick (changes no native state). Reuses action_webhook_sale_order_state;
        the sale.order worker branch pushes canonical metadata alongside the
        (idempotent) state sync. Same 5s dedup bucket → ≤1 job per order.
    -->
    <record id="auto_sync_sale_order_justix_status" model="base.automation">
        <field name="name">Sync sale.order justix_status to Saleor</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('saleor_sync.field_sale_order__justix_status')])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_sale_order_state'))]"/>
    </record>

    <record id="auto_sync_stock_picking_done" model="base.automation">
        <field name="name">Sync picking done to Saleor</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('stock.field_stock_picking__state')])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_stock_picking_done'))]"/>
    </record>

    <!--
        Phase 3.5 (ADR-0023/0027): атрибуты и значения → Saleor.
        trigger_field_ids узко на пользовательски-значимых полях (name + тип/цвет),
        чтобы не шуметь на служебных пересчётах.
    -->
    <record id="auto_sync_product_attribute" model="base.automation">
        <field name="name">Sync attribute to Saleor</field>
        <field name="model_id" ref="product.model_product_attribute"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('product.field_product_attribute__name'),
            ref('product.field_product_attribute__display_type'),
        ])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_product_attribute'))]"/>
    </record>

    <record id="auto_sync_product_attribute_value" model="base.automation">
        <field name="name">Sync attribute value to Saleor</field>
        <field name="model_id" ref="product.model_product_attribute_value"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('product.field_product_attribute_value__name'),
            ref('product.field_product_attribute_value__html_color'),
        ])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_product_attribute_value'))]"/>
    </record>

    <!--
        Phase 3.5 (ADR-0024): product.product (variant) изменения.
        trigger_field_ids: default_code (SKU) / barcode / active. БЕЗ lst_price —
        оно non-stored compute (нельзя триггерить); цены идут через template + PTAV.
    -->
    <record id="auto_sync_product_product" model="base.automation">
        <field name="name">Sync variant to Saleor</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('product.field_product_product__default_code'),
            ref('product.field_product_product__barcode'),
            ref('product.field_product_product__active'),
        ])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_product_product'))]"/>
    </record>

    <!--
        Phase 3.5 (ADR-0026): PTAV.price_extra → ре-синк цен вариантов шаблона.
        Источник вариантной надбавки; lst_price на варианте non-stored.
    -->
    <record id="auto_sync_ptav_price" model="base.automation">
        <field name="name">Sync PTAV price to Saleor</field>
        <field name="model_id" ref="product.model_product_template_attribute_value"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [
            ref('product.field_product_template_attribute_value__price_extra'),
        ])]"/>
        <field name="action_server_ids" eval="[(4, ref('action_webhook_ptav_price'))]"/>
    </record>
</odoo>
