<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="saleor_binding_view_list" model="ir.ui.view">
        <field name="name">saleor.binding.list</field>
        <field name="model">saleor.binding</field>
        <field name="arch" type="xml">
            <list string="Saleor Bindings" decoration-danger="sync_state == 'failed'"
                  decoration-warning="sync_state == 'diverged'"
                  decoration-muted="sync_state == 'pending'">
                <field name="model_name"/>
                <field name="odoo_id"/>
                <field name="odoo_ref"/>
                <field name="saleor_id"/>
                <field name="sync_state"/>
                <field name="last_sync_in"/>
                <field name="last_sync_out"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="saleor_binding_view_form" model="ir.ui.view">
        <field name="name">saleor.binding.form</field>
        <field name="model">saleor.binding</field>
        <field name="arch" type="xml">
            <form string="Saleor Binding">
                <sheet>
                    <group>
                        <group>
                            <field name="model_name"/>
                            <field name="odoo_id"/>
                            <field name="odoo_ref"/>
                            <field name="saleor_id"/>
                        </group>
                        <group>
                            <field name="sync_state"/>
                            <field name="last_sync_in"/>
                            <field name="last_sync_out"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Error Details" invisible="sync_state != 'failed'">
                            <field name="error_message" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="saleor_binding_view_search" model="ir.ui.view">
        <field name="name">saleor.binding.search</field>
        <field name="model">saleor.binding</field>
        <field name="arch" type="xml">
            <search string="Saleor Bindings">
                <field name="saleor_id"/>
                <field name="model_name"/>
                <field name="odoo_ref"/>
                <separator/>
                <filter string="Failed" name="failed" domain="[('sync_state', '=', 'failed')]"/>
                <filter string="Diverged" name="diverged" domain="[('sync_state', '=', 'diverged')]"/>
                <filter string="Pending" name="pending" domain="[('sync_state', '=', 'pending')]"/>
                <filter string="Synced" name="synced" domain="[('sync_state', '=', 'synced')]"/>
                <group name="group_by">
                    <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'sync_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="saleor_binding_action" model="ir.actions.act_window">
        <field name="name">Saleor Bindings</field>
        <field name="res_model">saleor.binding</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="saleor_binding_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Saleor↔Odoo external ID mapping table.
            </p>
            <p>
                Records are created automatically as records are synced between the
                two systems. Here you can see the mapping pairs and their status.
            </p>
        </field>
    </record>

    <!-- Top-level menu Saleor Sync -->
    <menuitem id="menu_saleor_sync_root"
              name="Saleor Sync"
              sequence="80"/>

    <menuitem id="menu_saleor_binding"
              name="Bindings"
              parent="menu_saleor_sync_root"
              action="saleor_binding_action"
              sequence="10"/>

</odoo>
