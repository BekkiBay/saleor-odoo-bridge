<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="saleor_outbox_view_list" model="ir.ui.view">
        <field name="name">saleor.outbox.list</field>
        <field name="model">saleor.outbox</field>
        <field name="arch" type="xml">
            <list string="Saleor Outbox" decoration-danger="state == 'failed'"
                  decoration-muted="state == 'sent'" create="false">
                <field name="create_date"/>
                <field name="model_name"/>
                <field name="odoo_id"/>
                <field name="action"/>
                <field name="state"/>
                <field name="response_code"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="saleor_outbox_view_form" model="ir.ui.view">
        <field name="name">saleor.outbox.form</field>
        <field name="model">saleor.outbox</field>
        <field name="arch" type="xml">
            <form string="Saleor Outbox" create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="model_name"/>
                            <field name="odoo_id"/>
                            <field name="action"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="response_code"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload" nolabel="1"/>
                        </page>
                        <page string="Error" invisible="state != 'failed'">
                            <field name="error_message" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="saleor_outbox_view_search" model="ir.ui.view">
        <field name="name">saleor.outbox.search</field>
        <field name="model">saleor.outbox</field>
        <field name="arch" type="xml">
            <search string="Saleor Outbox">
                <field name="model_name"/>
                <field name="odoo_id"/>
                <separator/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group name="group_by">
                    <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="saleor_outbox_action" model="ir.actions.act_window">
        <field name="name">Saleor Outbox</field>
        <field name="res_model">saleor.outbox</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="saleor_outbox_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Outbound события Odoo → Saleor (audit).
            </p>
            <p>
                Каждое create/write product.template и product.category пишет сюда
                запись + результат POST в middleware (Phase 3.2).
            </p>
        </field>
    </record>

    <menuitem id="menu_saleor_outbox"
              name="Outbox"
              parent="menu_saleor_sync_root"
              action="saleor_outbox_action"
              sequence="20"/>

</odoo>
